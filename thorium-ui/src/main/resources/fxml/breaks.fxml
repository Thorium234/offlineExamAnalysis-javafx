<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.BreakConfigurationController" spacing="12">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Break Configuration" styleClass="page-title"/>
    <TableView fx:id="breakTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
            <TableColumn fx:id="afterColumn" text="After Period" prefWidth="100"/>
            <TableColumn fx:id="durationColumn" text="Duration (min)" prefWidth="100"/>
            <TableColumn fx:id="startColumn" text="Start" prefWidth="80"/>
            <TableColumn fx:id="endColumn" text="End" prefWidth="80"/>
        </columns>
    </TableView>
    <GridPane hgap="8" vgap="8">
        <Label text="Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="After Period" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Spinner fx:id="afterSpinner" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Duration (min)" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Spinner fx:id="durationSpinner" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Start" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="startCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="140"/>
        <Label text="End" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="endCombo" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="140"/>
        <Label text="Sort Order" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <Spinner fx:id="sortSpinner" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button fx:id="saveBtn" text="Save" onAction="#onSave"/>
        <Button fx:id="deleteBtn" text="Delete" onAction="#onDelete"/>
        <Button fx:id="clearBtn" text="Clear" onAction="#onClear"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="generateBtn" text="Generate Defaults" onAction="#onGenerateDefaults"/>
    </HBox>
    <Label fx:id="messageLabel"/>
</VBox>
