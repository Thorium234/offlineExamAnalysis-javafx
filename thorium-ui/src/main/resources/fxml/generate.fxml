<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.TimetableGenerationController" spacing="16">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Timetable Generation" styleClass="page-title"/>
    <Label text="Configure teachers, subjects, classes, assignments, and periods before generating."/>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Timetable Name:"/>
        <TextField fx:id="nameField" promptText="Optional name" prefWidth="300"/>
        <Button fx:id="generateBtn" text="Generate Timetable" onAction="#onGenerate" styleClass="primary-button"/>
    </HBox>
    <Label fx:id="resultLabel" wrapText="true"/>
    <Label fx:id="qualityLabel"/>
</VBox>
