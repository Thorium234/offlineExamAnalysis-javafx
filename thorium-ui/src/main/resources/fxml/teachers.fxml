<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.TeacherManagementController" spacing="12">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Teacher Management" styleClass="page-title"/>
    <TextField fx:id="searchField" promptText="Search teachers by name or code..."/>
    <TableView fx:id="teacherTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="codeColumn" text="Code" prefWidth="100"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
            <TableColumn fx:id="maxDayColumn" text="Max/Day" prefWidth="80"/>
            <TableColumn fx:id="maxWeekColumn" text="Max/Week" prefWidth="80"/>
        </columns>
    </TableView>
    <GridPane hgap="8" vgap="8">
        <Label text="Code" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="codeField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Name" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Max/Day" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Spinner fx:id="maxDaySpinner" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Max/Week" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Spinner fx:id="maxWeekSpinner" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <CheckBox fx:id="activeCheck" text="Active" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>
    <HBox spacing="8">
        <Button fx:id="saveBtn" text="Save" onAction="#onSave" defaultButton="true"/>
        <Button fx:id="deleteBtn" text="Delete" onAction="#onDelete"/>
        <Button fx:id="clearBtn" text="Clear" onAction="#onClear"/>
    </HBox>
    <Label fx:id="messageLabel"/>
    <Separator/>
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Teaching Contracts (Lessons)" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newLessonBtn" text="New Lesson" onAction="#onNewLesson" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
    </HBox>
    <TableView fx:id="lessonTable" prefHeight="160">
        <columns>
            <TableColumn fx:id="lessonSubjectColumn" text="Subject" prefWidth="150"/>
            <TableColumn fx:id="lessonClassColumn" text="Class" prefWidth="150"/>
            <TableColumn fx:id="lessonCountColumn" text="Lessons/Week" prefWidth="100"/>
            <TableColumn fx:id="lessonDurationColumn" text="Duration" prefWidth="80"/>
            <TableColumn fx:id="lessonDeleteColumn" text="" prefWidth="50"/>
        </columns>
    </TableView>
</VBox>
