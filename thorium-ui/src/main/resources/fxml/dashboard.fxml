<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.DashboardController" spacing="16">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Dashboard" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshBtn" text="Refresh" onAction="#onRefresh"/>
    </HBox>
    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints percentWidth="33"/>
            <ColumnConstraints percentWidth="33"/>
            <ColumnConstraints percentWidth="33"/>
        </columnConstraints>
        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <StackPane fx:id="teachersIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Teachers" styleClass="stat-label"/>
            <Label fx:id="teachersCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <StackPane fx:id="subjectsIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Subjects" styleClass="stat-label"/>
            <Label fx:id="subjectsCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
            <StackPane fx:id="classesIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Classes" styleClass="stat-label"/>
            <Label fx:id="classesCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <StackPane fx:id="assignmentsIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Assignments" styleClass="stat-label"/>
            <Label fx:id="assignmentsCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <StackPane fx:id="totalLessonsIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Total Lessons/Week" styleClass="stat-label"/>
            <Label fx:id="totalLessonsCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="1">
            <StackPane fx:id="roomsIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Rooms" styleClass="stat-label"/>
            <Label fx:id="roomsCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <StackPane fx:id="timetablesIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Timetables" styleClass="stat-label"/>
            <Label fx:id="timetablesCount" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <StackPane fx:id="latestIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Latest Timetable" styleClass="stat-label"/>
            <Label fx:id="latestTimetable" text="None" styleClass="stat-value-small"/>
        </VBox>
        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="2">
            <StackPane fx:id="workloadIcon" prefWidth="32" prefHeight="32"/>
            <Label text="Teachers >90% Load" styleClass="stat-label"/>
            <Label fx:id="workloadCount" text="0" styleClass="stat-value"/>
        </VBox>
    </GridPane>
</VBox>
