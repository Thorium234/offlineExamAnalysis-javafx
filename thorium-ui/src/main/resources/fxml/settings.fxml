<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.SettingsController" spacing="12">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Settings" styleClass="page-title"/>
    <Label text="Database Location:"/>
    <Label fx:id="dbPathLabel" wrapText="true"/>
    <Label text="CBC no-double-lesson rule is enabled by default. Manage constraints in the database."/>
</VBox>
